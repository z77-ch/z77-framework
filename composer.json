{
    "name": "z77-ch/z77-framework",
    "description": "Z77 – PHP MVC framework monorepo. Develops the four z77 Composer packages (kernel, module-frontend, module-backend, module-dms) in one place; each is split into its own read-only consume repo on push. ⚠️ In development – not ready for production use.",
    "type": "project",
    "license": "MIT",
    "homepage": "https://github.com/z77-ch/z77-framework",
    "authors": [
        {
            "name": "Peter Ruepp",
            "email": "peter.ruepp@z77.ch"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.2",
        "z77/kernel": "^1.0",
        "z77/module-frontend": "^1.0",
        "z77/module-backend": "^1.0",
        "z77/module-dms": "^1.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "support": {
        "issues": "https://github.com/z77-ch/z77-framework/issues",
        "source": "https://github.com/z77-ch/z77-framework"
    }
}
