{
    "name": "z77/module-frontend",
    "description": "Z77 Frontend Module | the public-facing site: routing, pages, navigation and localized rendering.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Peter Ruepp",
            "email": "peter.ruepp@z77.ch"
        }
    ],
    "autoload": {
        "psr-4": {
            "Z77\\Module\\Frontend\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "require": {
        "php": ">=8.2",
        "z77/kernel": "^1.0"
    },
    "support": {
        "issues": "https://github.com/z77-ch/module-frontend/issues",
        "source": "https://github.com/z77-ch/module-frontend"
    },
    "readme": "README.md"
}
